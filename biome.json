{
    "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
    "files": {
        "includes": [
            "src/**/*.ts",
            "scripts/**/*.ts",
            "tests/**/*.ts",
            "vitest.config.ts",
            "package.json",
            "tsconfig.json",
            "tsconfig.build.json",
            "biome.json"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "style": {
                "noNonNullAssertion": "off"
            }
        }
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
